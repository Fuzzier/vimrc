########################################
# Conditional
########################################
snippet if "if"
if (${1:condition}) {
    ${2:${VISUAL}}
}
endsnippet

snippet ifc "if constexpr"
if constexpr (${1:condition}) {
    ${2:${VISUAL}}
}
endsnippet

snippet ife "if enum class"
if (${1:E}::None < ${2:`!p snip.rv=type2var(t[1])`} && $2 < $1::Last) {
    ${3:${VISUAL}}
}
endsnippet

snippet ifef "if enum class"
if (${1:E}::First <= ${2:`!p snip.rv=type2var(t[1])`} && $2 < $1::Last) {
    ${3:${VISUAL}}
}
endsnippet

snippet elif "else if"
else if (${1:condition}) {
    ${2:${VISUAL}}
}
endsnippet

snippet else "else"
else {
    ${1:${VISUAL}}
}
endsnippet

snippet switch "switch"
switch (${1:v}) {
$0
default:
    break;
}
endsnippet

snippet case "case"
case ${1:value} :
    $0
    break;
endsnippet

