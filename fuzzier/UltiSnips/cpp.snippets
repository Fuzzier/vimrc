# Loop
########################################
snippet for "for (++)"
for (${1:size_t} ${2:i} = ${3:0u}; $2 < ${4:N}; ++$2) {
    ${5:${VISUAL}}
}
endsnippet

snippet for1 "for (++)"
for (${1:size_t} ${2:i} = ${3:1u}; $2 <= ${4:N}; ++$2) {
    ${5:${VISUAL}}
}
endsnippet

snippet fori "for (++)"
for (${1:int} ${2:i} = ${3:0}; $2 < ${4:N}; ++$2) {
    ${5:${VISUAL}}
}
endsnippet

snippet foru "for (++)"
for (${1:unsigned} ${2:i} = ${3:0}; $2 < ${4:N}; ++$2) {
    ${5:${VISUAL}}
}
endsnippet

snippet for16 "for (uint16_t ++)"
for (uint16_t ${1:i} = 0u; $1 < ${2:N}; ++$1) {
    ${3:${VISUAL}}
}
endsnippet

snippet for32 "for (uint32_t ++)"
for (uint32_t ${1:i} = 0u; $1 < ${2:N}; ++$1) {
    ${3:${VISUAL}}
}
endsnippet

snippet for64 "for (uint64_t ++)"
for (uint64_t ${1:i} = 0u; $1 < ${2:N}; ++$1) {
    ${3:${VISUAL}}
}
endsnippet

snippet fort "for (iterator)"
for (auto ${1:it} = ${2:cont}.begin(); $1 != $2.end(); ++$1) {
    ${3:${VISUAL}}
}
endsnippet

snippet fort+ "for (iterator)"
for (auto ${1:it} = ${2:cont}.begin(); $1 != $2.end(); ) {
    ${3:${VISUAL}}
}
endsnippet

snippet fort> "for (iterator)"
for (auto ${1:it} = ${2:cont}->begin(); $1 != $2->end(); ++$1) {
    ${3:${VISUAL}}
}
endsnippet

snippet for>+ "for (iterator)"
for (auto ${1:it} = ${2:cont}->begin(); $1 != $2->end(); ) {
    ${3:${VISUAL}}
}
endsnippet

snippet forr "for (x : C)"
for (${1:T} ${2:`!p snip.rv=type2var(t[1])`} : ${3:cont}) {
    ${4:${VISUAL}}
}
endsnippet

snippet fora "for (auto& : C)"
for (auto& ${1:x} : ${2:$1Set}) {
    ${3:${VISUAL}}
}
endsnippet

snippet forc "for (const auto& : C)"
for (const auto& ${1:x} : ${2:$1Set}) {
    ${3:${VISUAL}}
}
endsnippet

snippet fore "for enum class"
for (size_t ${3:`!p snip.rv=first_char(type2var(t[1]))`} = 1u; $3 < k${2:`!p snip.rv=var2type(type2var(t[1]))`}Last; ++$3) {
    const auto ${4:`!p snip.rv=type2var(t[1])`} = static_cast<${1:E}>($3);
}
endsnippet

snippet foref "for enum class"
for (size_t ${3:`!p snip.rv=first_char(type2var(t[1]))`} = k${2:`!p snip.rv=var2type(type2var(t[1]))`}First; $3 < k$2Last; ++$3) {
    const auto ${4:`!p snip.rv=type2var(t[1])`} = static_cast<${1:E}>($3);
}
endsnippet

snippet while "while"
while (${1:1}) {
    ${2:${VISUAL}}
}
endsnippet

snippet dow "do while"
do { // while ($1)
    ${2:${VISUAL}}
} while (${1:0});
endsnippet

snippet be "begin(), end()" w
${1:${VISUAL:vec_}}.begin(), $1.end()
endsnippet

snippet cbe "cbegin(), cend()" w
${1:${VISUAL:vec_}}.cbegin(), $1.cend()
endsnippet

snippet efl "enum first/last"
constexpr auto k${2:`!p snip.rv=upperFirst(type2var(t[1]))`}First = static_cast<size_t>(${1:E}::First);
constexpr auto k$2Last  = static_cast<size_t>($1::Last);
endsnippet

snippet u2e "uint to enum"
const auto ${3:`!p snip.rv=type2var(t[1])`} = static_cast<${1:E}>(${2:value});
endsnippet

snippet e2u "enum to uint"
const auto ${2:`!p snip.rv=first_char(type2var(t[1]))`} = static_cast<size_t>(${1:value});
endsnippet

########################################
# Error handling
########################################
snippet try "try"
try {
    ${1:${VISUAL}}$0
}
endsnippet

snippet catch "catch"
catch (${1:Exception}& e) {
    ${1:${VISUAL}}$0
}
endsnippet

snippet cats "catch (std::exception &)"
catch (std::exception& e) {
    fmt::println(stderr, "{}", e.what());
}
endsnippet

snippet trys "try/catch"
try {
    ${1:${VISUAL}}$0
} catch (std::exception& e) {
    fmt::println(stderr, "{}", e.what());
}
endsnippet

snippet try. "try/catch"
try {
    ${1:${VISUAL}}$0
} catch (...) {
    throw;
}
endsnippet

snippet cata "catch (bad_alloc)"
catch (std::bad_alloc&) {
    $0
}
endsnippet

snippet cat. "catch (...)"
catch (...) {
    $0
    throw;
}
endsnippet

# Unindent 4 spaces.
# 2 = 2 (length of 'e:')
pre_expand "snip.buffer[snip.line]=' '*(len(snip.buffer[snip.line])-2); snip.cursor.set(snip.line, snip.column)"
snippet e: "exit:" b
exit:
endsnippet

# Unindent 4 spaces.
# 6 = 2 (length of 'e;') + 4 (indent width)
pre_expand "snip.buffer[snip.line]=' '*(len(snip.buffer[snip.line])-6); snip.cursor.set(snip.line, snip.column)"
snippet e; "exit:;" b
exit:
    return;
endsnippet

snippet ge "goto exit;"
goto exit;
endsnippet

