snippet contml "map-list container"
bool empty(void) const noexcept { return ${1:list_}.empty(); }

size_t size(void) const noexcept { return $1.size(); }

size_t count($3 $4) const noexcept {
    return ${2:map_}.count($4);
}

bool contains($3 $4) const noexcept {
    return $2.contains($4);
}

${5:T}* find(${3:Key} ${4:`!p snip.rv=type2var(t[3])`}) noexcept {
    const auto& self = *this;
    return const_cast<$5*>(self.find($4));
}

const $5* find($3 $4) const noexcept {
    auto it = $2.find($4);
    return (it != $2.end()) ? std::addressof(*it) : nullptr;
}

/// Returns the element that would expire first.
$5& front(void) noexcept { return $1.front(); }

/// Returns the element that would expire first.
const $5& front(void) const noexcept { return $1.front(); }

/// Returns the element that would expire last.
$5& back(void) noexcept { return $1.back(); }

/// Returns the element that would expire last.
const $5& back(void) const noexcept { return $1.back(); }

/// Asserts that the new element's lifetime is no shorter than
/// the existing ones.
bool _checkTime(simtime_t time) const noexcept {
    if (!empty()) {
        const $5& $6 = $1.back();
        NSFX_ASSERT($6.time_ <= time);
    }
    return true;
}

$5& _add($3 $4, simtime_t time) {
    NSFX_ASSERT(_checkTime(time));
    std::unique_ptr<$5> ${6:`!p snip.rv=type2var(t[5])`} {
        new $5{*this, $4, time} };
    auto result = $2.insert(*$6);
    NSFX_ASSERT(result.second);
    $1.push_back(*$6);
    return *$6.release();
}

struct AddResult {
    $5& value(void) const noexcept { return *value_; }
    $5* value_;
    bool added_;
};

AddResult _addOrGet($3 $4, simtime_t time) {
    NSFX_ASSERT(_checkTime(time));
    auto ins = $2.insert_check($4);
    if (ins.has_value()) {
        return {std::addressof(ins.value()), false};
    } else {
        std::unique_ptr<$5> $6 {
            new $5{*this, $4, time} };
        $2.insert_commit(*$6, ins);
        $1.push_back(*$6);
        return {std::addressof(*$6.release()), true};
    }
}

/// Renews the lifetime of the specified element.
void _refresh($5& $6, simtime_t time) noexcept {
    NSFX_ASSERT(_checkTime(time));
    $6.time_ = time;
    $1.unlink($6);
    $1.push_back($6);
}

/// Erases expired elements.
void _purge(simtime_t time) noexcept {
    while (!$1.empty()) {
        const $5& $6 = $1.front();
        if ($6.time_ <= time) {
            _pop_front();
            continue;
        }
        break;
    }
}

/// Erases the element that expires first.
void _pop_front(void) noexcept {
    NSFX_ASSERT(!empty());
    $1.pop_front_and_dispose([=] ($5* $6) noexcept {
        $2.unlink(*$6);
        delete $6;
    });
}

void _erase($3 $4) noexcept {
    size_t count = $2.erase_and_dispose($4,
        [=] ($5* $6) noexcept {
            $1.unlink(*$6);
            delete $6;
        });
    NSFX_ASSERT(count);
}

void _erase($5& $6) noexcept {
    $1.unlink($6);
    $2.unlink_and_dispose($6, [] ($5* $6) noexcept {
        delete $6;
    });
}

void _clear(void) noexcept {
    $2.abandon();
    $1.clear_and_dispose([] ($5* $6) noexcept {
        delete $6;
    });
}
endsnippet

