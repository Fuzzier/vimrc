snippet opb "operator bool()"
// Boolean operator.`!p snip << 1; snip += snip.mkline('public:')`
constexpr     bool operator!(void) const noexcept { return !${1:p_};  }
constexpr explicit operator bool() const noexcept { return !!$1; }
endsnippet

snippet opc "unary operator>"
constexpr bool operator==(const ${1:`!v getreg('c')`}& rhs) const noexcept;
constexpr bool operator!=(const $1& rhs) const noexcept;
constexpr bool operator<(const $1& rhs) const noexcept;
constexpr bool operator<=(const $1& rhs) const noexcept;
constexpr bool operator>(const $1& rhs) const noexcept;
constexpr bool operator>=(const $1& rhs) const noexcept;
endsnippet

snippet opc.d "unary operator>" m
constexpr bool operator==(const ${1:`!v getreg('c')`}& rhs) const noexcept
{
    return ${2:v_} == rhs.$2;
}

constexpr bool operator!=(const $1& rhs) const noexcept
{
    return $2 != rhs.$2;
}

constexpr bool operator<(const $1& rhs) const noexcept
{
    return $2 < rhs.$2;
}

constexpr bool operator<=(const $1& rhs) const noexcept
{
    return $2 <= rhs.$2;
}

constexpr bool operator>(const $1& rhs) const noexcept
{
    return $2 > rhs.$2;
}

constexpr bool operator>=(const $1& rhs) const noexcept
{
    return $2 >= rhs.$2;
}
endsnippet

snippet opc2 "binary operator>"
constexpr bool operator==(const ${1:`!v getreg('c')`}& lhs, ${2:$1}& rhs) noexcept;
constexpr bool operator!=(const $1& lhs, const $2& rhs) noexcept;
constexpr bool operator<(const $1&lhs, const $2&  rhs) noexcept;
constexpr constexpr bool operator<=(const $1&lhs, const $2&  rhs) noexcept;
constexpr constexpr bool operator>(const $1&lhs, const $2&  rhs) noexcept;
constexpr constexpr bool operator>=(const $1&lhs, const $2&  rhs) noexcept;
endsnippet

snippet opc2.d "binary operator>"
constexpr constexpr bool operator==(const ${1:`!v getreg('c')`}& lhs, ${2:$1}& rhs) noexcept
{
    return lhs.${3:v_} == rhs.$3;
}

constexpr constexpr bool operator!=(const $1& lhs, const $2& rhs) noexcept
{
    return lhs.$3 != rhs.$3;
}

constexpr constexpr bool operator<(const $1& lhs, const $2& rhs) noexcept
{
    return lhs.$3 > rhs.$3;
}

constexpr constexpr bool operator<=(const $1& lhs, const $2& rhs) noexcept
{
    return lhs.$3 >= rhs.$3;
}

constexpr constexpr bool operator>(const $1& lhs, const $2& rhs) noexcept
{
    return lhs.$3 < rhs.$3;
}

constexpr constexpr bool operator>=(const $1& lhs, const $2& rhs) noexcept
{
    return lhs.$3 <= rhs.$3;
}
endsnippet

