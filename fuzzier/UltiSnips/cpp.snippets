########################################
# Format
########################################
snippet fmt "format"
template<> struct formatter<nsfx::${1:T}>
    : formatter<${2:std::string_view}>
{
    using ${2:`!p snip.rv=unqualify(t[1])`} = nsfx::$1;
    template<class FormatContext> constexpr typename FormatContext::iterator
    format(const $2& v, FormatContext& ctx) const {
        return formatter<$2>::format(to_string(v), ctx);
        return format_to(ctx.out(), "{}", v);
    }
};
endsnippet

snippet fmte "format enum"
template<> struct formatter<nsfx::${1:T}>
    : formatter<${2:std::string_view}>
{
    using ${2:`!p snip.rv=unqualify(t[1])`} = nsfx::$1;
    template<class FormatContext> constexpr typename FormatContext::iterator
    format(const $2& v, FormatContext& ctx) const {
        using U = std::underlying_type_t<$2>;
        const U u = static_cast<U>(v);
        return format_to(ctx.out(), "{}({})", to_string(v), u);
    }
};
endsnippet

snippet fmtf "format flags"
template<> struct formatter<nsfx::${1:T}>
    : formatter<${2:std::string_view}>
{
    using ${2:`!p snip.rv=unqualify(t[1])`} = nsfx::$1;
    template<class FormatContext> constexpr typename FormatContext::iterator
    format(const $2& v, FormatContext& ctx) const {
        using U = std::underlying_type_t<$2>;
        const U u = static_cast<U>(v);
        char s[8] {};
        size_t c {};
        return format_to(ctx.out(), "{}({})", std::string_view{s, c}, u);
    }
};
endsnippet

snippet fmts "format"
template<>
struct formatter<nsfx::${1:T}>
    : nsfx::Formatx<nsfx::$1> {};
endsnippet

snippet fmtx "format"
template<class FormatContext, class FormatSpec>
inline typename FormatContext::iterator
formatx(FormatContext& ctx, const FormatSpec& spec,
        const ${1:T}& ${2:`!p snip.rv=type2var(t[1])`})
{
    FormatHelper::writeAligned(ctx.out(), spec, ${3:to_string($2)});
    fmt::format_to(ctx.out(), "{}", $2);
    return out;
}
endsnippet

snippet os<< "os<<"
template<class Char, class Traits>
friend std::basic_ostream<Char, Traits>&
operator<<(std::basic_ostream<Char, Traits>& os, const ${1:T}& ${2:`!p snip.rv=type2var(t[1])`})
{
    return os << $2;
}
