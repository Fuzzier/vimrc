snippet dmod "declare module"
public:
    explicit
    ${1:T}(void) = default;
    virtual ~$1(void) = default;

    // Object
public:
    virtual std::string_view className(void) const noexcept override
    { return Object::className(this); }

    // Module
public:
    virtual void* query(std::string_view iid) noexcept override;
    virtual void use(std::string_view iid, void* p) override;
    virtual void initialize(const JsonVar& cfg) override;
    virtual void on(const Event& ev) override;
    virtual void handle(Message&& msg) override;

    // 参数及数据结构.
private:

    // 事件.
private:
    enum class EventId {
        None,
        Last,
    };

    // 端口.
private:
    enum class PortId {
        None,
        Last,
    };
endsnippet

