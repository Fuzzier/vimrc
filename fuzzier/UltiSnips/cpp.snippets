$1& operator=(const $1& rhs);
endsnippet

# // Copyable.`!p snip << 1; snip += snip.mkline('public:')`
snippet cpyd "Copyable"
${1:`!v getreg('c')`}(const $1& ) noexcept = default;
$1& operator=(const $1& ) noexcept = default;
endsnippet

# // Copyable.`!p snip << 1; snip += snip.mkline('public:')`
snippet cpy.d "Copyable" m
${1:`!v getreg('c')`}(const $1& rhs)
    : $0
{
}

$1& operator=(const $1& rhs)
{
    if (this != std::addressof(rhs)) {
        $0
    }
    return *this;
}
endsnippet

# // Movable.`!p snip << 1; snip += snip.mkline('public:')`
snippet mov "Movable"
${1:`!v getreg('c')`}($1&& rhs) noexcept;
$1& operator=($1&& rhs) noexcept;
endsnippet

# // Movable.`!p snip << 1; snip += snip.mkline('public:')`
snippet movd "Movable"
${1:`!v getreg('c')`}($1&& rhs) noexcept = default;
