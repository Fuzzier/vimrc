snippet cont "container"
void initialize(void);

bool empty(void) const noexcept { return ${3:map_}.empty(); }

bool full(void) const noexcept { return $3.full(); }

size_t size(void) const noexcept { return $3.size(); }

size_t capacity(void) const noexcept { return $3.capacity(); }

void reserve(size_t n) { $3.reserve(n); }

void resize(size_t n) { $3.resize(n); }

$1*
front(void) noexcept { return $3.front(); }

const $1*
front(void) const noexcept { return $3.front(); }

size_t count($2) const noexcept;

bool contains($2) const noexcept;

$1*
find($2) noexcept;

const ${1:T}*
find(${2:key}) const noexcept;

$1* add($2);

$1* addOrGet($2);

$1* addOrUpdate($2);

$1* push_back($2);

std::unique_ptr<$1>
pop_front(void) noexcept
{
    return std::unique_ptr<$1>{ $3.pop_front() };
}

void erase($2) noexcept;

void erase($1* `!p snip.rv=type2var(t[1])`) noexcept;

void clear(void) noexcept { $3.destroy(); }
endsnippet

snippet contv "vector-based container"
bool empty(void) const noexcept { return ${1:vec_}.empty(); }

size_t size(void) const noexcept { return $1.size(); }

void reserve(size_t count) { $1.reserve(count); }

void resize(size_t count) { $1.resize(count); }

${4:T}* find(${2:Key} ${3:`!p snip.rv=type2var(t[2])`}) noexcept {
    const auto& self = *this;
    return const_cast<$4*>(self.find($3));
}

const $4* find($2 $3) const noexcept {
    for (const $4& ${5:`!p snip.rv=type2var(t[4])`} : $1) {
        if ($5.$3_ == $3) {
            return std::addressof($5);
        }
    }
    return nullptr;
}

$4& at(size_t index) noexcept {
    return $1.at(index);
}

const $4& at(size_t index) const noexcept {
    return $1.at(index);
}

$4& front(void) noexcept { return $1.front(); }

const $4& front(void) const noexcept { return $1.front(); }

$4& back(void) noexcept { return $1.back(); }

const $4& back(void) const noexcept { return $1.back(); }

$4& _emplace_back($2 $3) {
    return $1.emplace_back($3);
}

void _pop_back(void) noexcept { return $1.pop_back(); }

struct AddResult {
    $4& value(void) const noexcept { return *value_; }
    $4* value_;
    bool added_;
};

AddResult _addOrGet($2 $3) {
    $4* $5 = find($3);
    if ($5) {
        return {$5, false};
    } else {
        return {std::addressof(_emplace_back($3)), true};
    }
}

void _clear(void) noexcept {
    $1.clear();
}
endsnippet

snippet contvs "sorted vector-based container"
bool empty(void) const noexcept { return ${1:map_}.empty(); }

size_t size(void) const noexcept { return $1.size(); }

void reserve(size_t count) { $1.reserve(count); }

void resize(size_t count) { $1.resize(count); }

size_t count($2 $3) const noexcept {
    return !!find($3);
}

bool contains($2 $3) const noexcept {
    return !!find($3);
}

bool contains(const $4& $5) const noexcept {
    const Comp comp{};
    auto it = std::lower_bound($1.begin(), $1.end(), $5, comp);
    if (it != $1.end()) {
        const $4& value = *it;
        if (!comp($5, value)) {
            return true;
        }
    }
    return false;
}

$4* find($2 $3) noexcept {
    const auto& self = *this;
    return const_cast<$4*>(self.find($3));
}

const ${4:T}* find(${2:Key} ${3:`!p snip.rv=type2var(t[2])`}) const noexcept {
    const Comp comp{};
    auto it = std::lower_bound($1.begin(), $1.end(), $3, comp);
    if (it != $1.end()) {
        const $4& ${5:`!p snip.rv=type2var(t[4])`} = *it;
        if (!comp($3, $5)) {
            return std::addressof($5);
        }
    }
    return nullptr;
}

$4& at($2 $3) noexcept {
    const auto& self = *this;
    return const_cast<$4&>(self.at($3));
}

const $4& at($2 $3) const noexcept {
    const $4* $5 = find($3);
    NSFX_ASSERT($5);
    return *$5;
}

$4& _add($2 $3) {
    NSFX_ASSERT(!contains($3));
    const Comp comp{};
    auto it = std::lower_bound($1.begin(), $1.end(), $3, comp);
    return *$1.emplace(it, $3);
}

struct AddResult {
    $4& value(void) const noexcept { return *value_; }
    $4* value_;
    bool added_;
};

AddResult _addOrGet($2 $3) {
    const Comp comp{};
    auto it = std::lower_bound($1.begin(), $1.end(), $3, comp);
    if (it != $1.end()) {
        $4& $5 = *it;
        if (!comp($3, $5)) {
            return {std::addressof($5), false};
        }
    }
    $4& $5 = *$1.emplace(it, $3);
    return {std::addressof($5), true};
}

size_t _erase($2 $3) noexcept {
    const Comp comp{};
    auto it = std::lower_bound($1.begin(), $1.end(), $3, comp);
    if (it != $1.end()) {
        const $4& $5 = *it;
        if (!comp($3, $5)) {
            $1.erase(it);
            return 1u;
        }
    }
    return 0u;
}

void _erase(const $4& $5) noexcept {
    NSFX_ASSERT(contains($5));
    const Comp comp{};
    auto it = std::lower_bound($1.begin(), $1.end(), $5, comp);
    $1.erase(it);
}

void _clear(void) noexcept {
    $1.clear();
}

void sort(void) noexcept {
    std::sort($1.begin(), $1.end(), Comp{});
}
endsnippet

