########################################
# Data structures
########################################
snippet key "Key"
struct ${1:Key} {
    $1() noexcept
    {}
    uint64_t to_uint(void) const noexcept {
        static_assert(sizeof(Key) == sizeof(uint64_t));
        uint64_t u{};
        std::memcpy(&u, this, sizeof(u));
        return u;
    }
    bool operator==(const Key& rhs) const noexcept {
        return to_uint() == rhs.to_uint();
    }
    bool operator<(const Key& rhs) const noexcept {
        return to_uint() < rhs.to_uint();
    }
};
endsnippet

snippet kof "keyof"
using Key = ${1:addr_t};
struct ${2:KeyOf} {
    constexpr ${3:Key} operator()(const ${4:T}& ${5:`!p snip.rv=type2var(t[4])`}) const noexcept {
        return $5.${6:`!p snip.rv=type2var(t[3])`_};
    }
};
endsnippet

snippet kcomp "Comp"
struct ${1:Comp} {
    using is_transparent = void;
    constexpr bool operator()($2 lhs, $2 rhs) const noexcept {
        return lhs < rhs;
    }
    constexpr bool operator()(${2:Key} ${3:`!p snip.rv=type2var(t[2])`}, const ${4:T}& rhs) const noexcept {
        return $3 < rhs.${5:$3_};
    }
    constexpr bool operator()(const $4& lhs, $2 $3) const noexcept {
        return lhs.$5 < $3;
    }
    constexpr bool operator()(const $4& lhs, const $4& rhs) const noexcept {
        return lhs.$5 < rhs.$5;
    }
};
endsnippet

snippet keq "KeyEqual"
struct ${1:KeyEqual} {
    using is_transparent = void;
    constexpr bool operator()(const ${2:T}& lhs, const $2& rhs) const noexcept {
        return lhs.${3:key_} == rhs.$3;
    }
    constexpr bool operator()(const $2& lhs, ${4:Key} ${5:`!p snip.rv=t[3].rstrip('_')`}) const noexcept {
        return lhs.$3 == $5;
    }
    constexpr bool operator()($4 $5, const $2& rhs) const noexcept {
        return $5 == rhs.$3;
    }
};
endsnippet

snippet khash "Hash"
struct ${1:Hash} {
    using is_transparent = void;
    constexpr size_t operator()(${2:Key} ${3:`!p snip.rv=type2var(t[2])`}) const noexcept {
        return hash_aux::moremur($3);
    }
};
endsnippet

snippet lcomp "lex comp"
if (lhs.${1:k0} != rhs.$1) {
    return lhs.$1 < rhs.$1;
} else {
    return lhs.${2:k1} < rhs.$2;
}
endsnippet

