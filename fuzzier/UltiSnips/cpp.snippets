    $4* value_;
    bool added_;
};

AddResult _addOrGet($2 $3) {
    $4* $5 = find($3);
    if ($5) {
        return {$5, false};
    } else {
        return {std::addressof(_add($3)), true};
    }
}

void _erase($2 $3) noexcept {
    $4* $5 = find($3);
    NSFX_ASSERT($5);
    $1.unlink_and_dispose(*$5, [] ($4* $5) noexcept {
        delete $5;
    });
}

void _erase($4& $5) noexcept {
    $1.unlink_and_dispose($5, [] ($4* $5) noexcept {
        delete $5;
    });
}

$4& _emplace_back($2 $3) {
    NSFX_ASSERT(!contains($3));
    std::unique_ptr<$4> $5 {
        new $4{*this, $3} };
    $1.push_back(*$5);
    return *$5.release();
}

void _pop_back(void) noexcept {
    $1.pop_back_and_dispose([] ($4* $5) noexcept {
        delete $5;
    });
    // FIXME
    $1.pop_back();
}

void _link($4& $5) {
    $1.push_back($5);
}

void _unlink($4& $5) noexcept {
    $1.unlink($5);
}

void _clear(void) noexcept {
    $1.clear_and_dispose([] ($4* $5) noexcept {
        delete $5;
    });
    // FIXME
    $1.clear();
