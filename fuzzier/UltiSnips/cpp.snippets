snippet dupush "du.push"
// 添加分组头部.
${1:T}* ${2:hdr} = nullptr;
{
    $2 = ${3:msg}.du().resetAndPush(type_tag<$1>);
    $0
    $3->addByteLength(sizeof($1));
}
endsnippet

snippet dupushv "du.push"
// 添加分组头部.
{
    ${1:msg}.du().resetAndPush(${2:hdr});
    $1->addByteLength(sizeof(${3:`!p snip.rv=var2type(t[2])`}));
}
endsnippet

snippet dupushp "du.push"
// 添加分组头部.
{
    ${1:msg}.du().resetAndPush(${2:p});
    $1->addByteLength(sizeof($2));
}
endsnippet

snippet dupushb "du.push"
// 添加分组头部.
{
    ${1:msg}.du().reset(type_tag<${2:T}>);
    uint8_t* buf = $1->du().push(sizeof(${3:`!p snip.rv=t[2].strip()`}), 0);
    $0
    $1->addByteLength(sizeof($3));
}
endsnippet

snippet dupop "du.pop"
// 提取分组头部.
${1:T} ${2:hdr};
{
    Buffer& du = ${3:msg}.du();
    NSFX_ASSERT(du.size() >= sizeof($1))(
        "Invalid $1 size {} B, expected no less than {} B",
        du.size(), sizeof($1));
    du.pop(&$2, sizeof($1));
    $0
    $3->addByteLength(0-sizeof($1));
}
endsnippet

snippet duptr "du.ptr"
// 读取分组头部.
const ${1:T}* ${2:hdr} = nullptr;
{
    const Buffer& du = ${3:msg}.du();
    NSFX_ASSERT(du.size() >= sizeof($1))(
        "Invalid $1 size {} B, expected no less than {} B",
        du.size(), sizeof($1));
    $2 = reinterpret_cast<const $1*>(du.data());
    $0
}
endsnippet

snippet dupeep "du.peep"
// 读取分组头部.
${1:T} ${2:hdr};
{
    const Buffer& du = ${3:msg}.du();
