snippet contl "list-based container"
bool empty(void) const noexcept { return ${1:list_}.empty(); }

size_t size(void) const noexcept { return $1.size(); }

size_t count($2 $3) const noexcept {
    return !!find($3);
}

bool contains($2 $3) const noexcept {
    return !!find($3);
}

${4:T}* find(${2:Key} ${3:`!p snip.rv=type2var(t[2])`}) noexcept {
    const auto& self = *this;
    return const_cast<$4*>(self.find($3));
}

const $4* find($2 $3) const noexcept {
    Equal eq;
    for (const $4& ${5:`!p snip.rv=type2var(t[4])`} : $1) {
        if (eq($5, $3)) {
            return std::addressof($5);
        }
    }
    return nullptr;
}

$4& front(void) noexcept { return $1.front(); }

const $4& front(void) const noexcept { return $1.front(); }

$4& back(void) noexcept { return $1.back(); }

const $4& back(void) const noexcept { return $1.back(); }

$4& _add($2 $3) {
    NSFX_ASSERT(!contains($3));
    std::unique_ptr<$4> $5 {
        new $4{*this, $3} };
    $1.push_back(*$5);
    return *$5.release();
}

struct AddResult {
